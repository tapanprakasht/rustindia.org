<section class="section-shell pb-24 md:pb-32">
  <div class="grid gap-8 lg:grid-cols-12">
    <article id="cfp" class="hero-glass rounded-[2rem] p-7 md:p-10 lg:col-span-8">
      <p class="section-kicker">CFP Is Open</p>
      <h2 class="mt-4 max-w-3xl font-display text-4xl font-semibold leading-tight text-rust-50">
        Bring your best Rust battle story to Bangalore.
      </h2>
      <p class="mt-4 max-w-3xl text-lg text-rust-100/90">
        Share practical learnings from migrations, performance tuning, reliability incidents, tooling workflows, and
        production architecture. New speakers are welcome.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="https://hasgeek.com/rustbangalore/cfp-rust-india-conference-2026/" class="cta-button cta-primary" target="_blank" rel="noreferrer">Submit CFP</a>
        <span class="rounded-full border border-white/20 bg-black/25 px-4 py-2 text-sm text-rust-100">Formats: 25 and 45 mins</span>
      </div>
    </article>

    <article class="hero-glass rounded-[2rem] p-7 md:p-8 lg:col-span-4">
      <p class="section-kicker">Conference Snapshot</p>
      <h3 class="mt-4 font-display text-3xl font-semibold text-rust-50">One focused day</h3>
      <div class="mt-5 grid gap-3 text-rust-100/95">
        <div class="rounded-2xl border border-white/15 bg-black/20 p-4">
          <p class="text-xs uppercase tracking-wider text-rust-200">Date</p>
          <p class="mt-1 font-display text-2xl text-rust-50">18 Apr 2026</p>
        </div>
        <div class="rounded-2xl border border-white/15 bg-black/20 p-4">
          <p class="text-xs uppercase tracking-wider text-rust-200">Day</p>
          <p class="mt-1 font-display text-2xl text-rust-50">Saturday</p>
        </div>
        <div class="rounded-2xl border border-white/15 bg-black/20 p-4">
          <p class="text-xs uppercase tracking-wider text-rust-200">Venue City</p>
          <p class="mt-1 font-display text-2xl text-rust-50">Bangalore</p>
        </div>
      </div>
    </article>

    <article id="mailing-list" class="hero-glass rounded-[2rem] p-7 md:p-8 lg:col-span-5">
      <p class="section-kicker">Mailing List</p>
      <h3 class="mt-4 font-display text-3xl font-semibold text-rust-50">Get the ticket drop first</h3>
      <p class="mt-3 text-rust-100/90">We will send only key updates: tickets, agenda, speakers, and important logistics.</p>

      <form
        class="mt-7 flex flex-col gap-3"
        action="https://docs.google.com/forms/d/e/1FAIpQLSf9QQD3qbXNT7pnjCFeJGM6eRfleFxVGc1_-vJSBjRxmeRb-A/formResponse"
        method="POST"
        target="hidden_iframe"
      >
        <label class="sr-only" for="email">Email</label>

        <!-- Honeypot anti-spam (invisible, no styling impact) -->
        <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off" />

        <input
          id="email"
          type="email"
          name="entry.2110698367"
          required
          placeholder="you@company.com"
          autocomplete="email"
          class="w-full rounded-full border border-white/20 bg-black/30 px-5 py-3 text-rust-50 placeholder:text-rust-100/65 focus:border-rust-300 focus:outline-none"
        />

        <button type="submit" class="cta-button cta-primary w-fit">Sign Up</button>
      </form>

      <p data-signup-msg class="mt-3 hidden text-sm text-rust-200">
        Thanks! You are on the updates list.
      </p>

      <!-- Hidden iframe prevents Google redirect -->
      <iframe name="hidden_iframe" style="display:none;"></iframe>
    </article>

