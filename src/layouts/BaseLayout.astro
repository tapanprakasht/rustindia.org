---
import Analytics from '@vercel/analytics/astro'
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Rust India Community",
  description = "Rust India Conference in Bengaluru - April 18, 2026."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="space-backdrop" aria-hidden="true">
      <div class="space-grid"></div>
      <div class="metro-lines" data-parallax="6"></div>
      <div class="city-nodes" data-parallax="-5"></div>
      <div class="ring-road" data-parallax="9"></div>
      <div class="urban-skyline" data-parallax="3"></div>
      <div class="signal-haze" data-parallax="-7"></div>
      <div class="space-orb space-orb-a" data-parallax="12"></div>
      <div class="space-orb space-orb-b" data-parallax="-16"></div>
      <div class="space-orb space-orb-c" data-parallax="8"></div>
    </div>
    <div class="grain-overlay" aria-hidden="true"></div>
    <slot />
    <script is:inline>
      const parallaxNodes = Array.from(document.querySelectorAll("[data-parallax]"));
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      if (!prefersReducedMotion.matches && parallaxNodes.length) {
        const finePointer = window.matchMedia("(pointer: fine)").matches;
        const controller = new AbortController();
        const signal = controller.signal;
        const state = {
          targetX: 0,
          targetY: 0,
          currentX: 0,
          currentY: 0,
          scrollRatio: 0
        };
        let frameId = 0;

        const updateScroll = () => {
          const maxScroll = Math.max(document.documentElement.scrollHeight - window.innerHeight, 1);
          state.scrollRatio = window.scrollY / maxScroll - 0.5;
        };

        if (finePointer) {
          window.addEventListener(
            "pointermove",
            (event) => {
              state.targetX = event.clientX / window.innerWidth - 0.5;
              state.targetY = event.clientY / window.innerHeight - 0.5;
            },
            { passive: true, signal }
          );
        }

        window.addEventListener("scroll", updateScroll, { passive: true, signal });
        updateScroll();

        const animate = (time) => {
          state.currentX += (state.targetX - state.currentX) * 0.08;
          state.currentY += (state.targetY - state.currentY) * 0.08;

          parallaxNodes.forEach((node) => {
            const depth = Number(node.getAttribute("data-parallax")) || 0;
            const driftX = Math.sin(time * 0.00012 + depth) * depth * 0.08;
            const driftY = Math.cos(time * 0.0001 + depth) * depth * 0.07;
            const tx = state.currentX * depth * 1.8 + driftX;
            const ty = state.currentY * depth * 1.5 + state.scrollRatio * depth * -2 + driftY;
            node.style.transform = `translate3d(${tx.toFixed(2)}px, ${ty.toFixed(2)}px, 0)`;
          });

          frameId = window.requestAnimationFrame(animate);
        };

        frameId = window.requestAnimationFrame(animate);

        window.addEventListener(
          "pagehide",
          () => {
            window.cancelAnimationFrame(frameId);
            controller.abort();
          },
          { once: true }
        );
      }
    </script>
  </body>
</html>
